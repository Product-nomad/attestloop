---
import evolution from "../content/runs/evolution.json";

function formatRuntime(seconds: number): string {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}m ${String(s).padStart(2, "0")}s`;
}

const columns = [
  "Version",
  "Approach",
  "Obligations",
  "Mappings",
  "Unmapped",
  "Cost (USD)",
  "Runtime",
];
---

<section
  id="numbers"
  class="border-t border-border-subtle py-24 sm:py-32 px-6 sm:px-8"
>
  <div class="max-w-[64rem] mx-auto fade-in">
    <p
      class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted mb-6"
    >
      Output
    </p>

    <h2
      class="font-serif font-normal text-text-primary text-[1.5rem] sm:text-[2rem] leading-tight mb-4"
    >
      What it produces
    </h2>

    <p
      class="text-base text-text-secondary leading-relaxed max-w-[42rem] mb-10"
    >
      Seven runs against the same source document. v1 through v5 walk the
      v1 architecture; v5_eq and v6 isolate the orchestration impact in
      v2.0.0.
    </p>

    <div class="border border-border-subtle bg-bg-elevated overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="border-b border-border-subtle">
            {
              columns.map((col, idx) => (
                <th
                  class:list={[
                    "px-4 py-3 text-xs font-mono uppercase tracking-[0.12em] text-text-secondary font-normal whitespace-nowrap",
                    idx >= 2 ? "text-right" : "text-left",
                  ]}
                >
                  {col}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            evolution.map((row, i) => (
              <tr
                class:list={[i > 0 && "border-t border-border-subtle"]}
              >
                <td class="px-4 py-4 text-sm font-mono text-text-primary whitespace-nowrap">
                  {row.version}
                </td>
                <td class="px-4 py-4 text-sm text-text-secondary leading-snug min-w-[18rem]">
                  {row.approach}
                </td>
                <td class="px-4 py-4 text-sm font-mono text-text-primary text-right whitespace-nowrap">
                  {row.obligations}
                </td>
                <td class="px-4 py-4 text-sm font-mono text-text-primary text-right whitespace-nowrap">
                  {row.mappings}
                </td>
                <td class="px-4 py-4 text-sm font-mono text-text-primary text-right whitespace-nowrap">
                  {row.unmapped}
                </td>
                <td class="px-4 py-4 text-sm font-mono text-text-primary text-right whitespace-nowrap">
                  ${row.cost_usd.toFixed(2)}
                </td>
                <td class="px-4 py-4 text-sm font-mono text-text-primary text-right whitespace-nowrap">
                  {formatRuntime(row.runtime_seconds)}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <p
      class="text-base text-text-secondary leading-relaxed max-w-[42rem] mt-10"
    >
      Six iterations from a 50,000-character truncated baseline to a
      LangGraph state machine with second-pass review and parallel
      execution. Each step kept the previous quality while changing one
      variable. The v6 canonical run produces the same Commission
      Guidelines attestation in 13 minutes 26 seconds at $2.09 — Mapper
      wall-clock 8.13× faster than v5_eq, total wall-clock essentially
      flat because the Critic adds ~3 minutes of sequential review work.
    </p>

    <p
      class="text-sm text-text-muted leading-relaxed max-w-[42rem] mt-6"
    >
      v3 → v4 caching delivered a 30× return on the cache write cost.
      v4 → v5 dedup removed 12 paraphrased duplicates that substring-match
      missed. v5 → v6 swapped sequential function calls for a typed state
      machine and 8-way concurrent Mapper. The v5_eq vs v6 pair isolates
      the orchestration impact under identical code. Read the writeup
      for the engineering detail.
    </p>

    <a
      href="/writeup"
      class="inline-flex items-center text-sm font-mono text-accent hover:text-accent-bright transition-colors duration-150 mt-8"
    >
      Read the writeup →
    </a>
  </div>
</section>
