<script>
  // Vanilla JS panel interactivity. Single panel open at a time. Click
  // an agent box to toggle its panel; clicking the same box closes it;
  // X button closes; arrow keys cycle through agents while a panel is
  // open; Escape closes.
  type State = { active: string | null };

  const state: State = { active: null };

  const boxes = Array.from(
    document.querySelectorAll<HTMLButtonElement>("button[data-agent-id]"),
  );
  const panels = Array.from(
    document.querySelectorAll<HTMLElement>("article[data-agent]"),
  );
  const order = boxes.map((b) => b.dataset.agentId ?? "");

  function show(id: string) {
    state.active = id;
    for (const p of panels) {
      const match = p.dataset.agent === id;
      if (match) p.removeAttribute("hidden");
      else p.setAttribute("hidden", "");
    }
    for (const b of boxes) {
      const match = b.dataset.agentId === id;
      b.setAttribute("aria-expanded", match ? "true" : "false");
    }
    const target = document.getElementById(`agent-panel-${id}`);
    if (target) {
      target.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }
  }

  function close() {
    state.active = null;
    for (const p of panels) p.setAttribute("hidden", "");
    for (const b of boxes) b.setAttribute("aria-expanded", "false");
  }

  for (const b of boxes) {
    b.addEventListener("click", () => {
      const id = b.dataset.agentId ?? "";
      if (!id) return;
      if (state.active === id) close();
      else show(id);
    });
  }

  for (const closer of document.querySelectorAll<HTMLButtonElement>(
    "button[data-panel-close]",
  )) {
    closer.addEventListener("click", close);
  }

  document.addEventListener("keydown", (e) => {
    if (state.active === null) return;
    if (e.key === "Escape") {
      close();
      e.preventDefault();
      return;
    }
    if (e.key === "ArrowRight" || e.key === "ArrowDown") {
      const i = order.indexOf(state.active);
      if (i >= 0 && i < order.length - 1) {
        show(order[i + 1]);
        e.preventDefault();
      }
    } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
      const i = order.indexOf(state.active);
      if (i > 0) {
        show(order[i - 1]);
        e.preventDefault();
      }
    }
  });

</script>

<script>
  // Render the LangGraph-generated Mermaid source into an SVG on mount.
  // Mermaid is lazy-loaded via dynamic import on intersection so the
  // ~600 KB bundle doesn't sit on the homepage's critical path. Source
  // is read from the host's data-mermaid-source attribute (not text
  // content) so Astro's HTML escaping doesn't double-escape the
  // <p>...</p> labels in the .mmd file. The rendered SVG replaces the
  // host's children outright so Astro's scoped CSS doesn't try to
  // attribute-tag elements Mermaid injected at runtime.

  async function renderPipelineDiagram() {
    const host = document.querySelector<HTMLDivElement>(
      "div.mermaid-host[data-mermaid-source]",
    );
    if (!host) return;
    const rawSource = host.getAttribute("data-mermaid-source") ?? "";
    if (!rawSource.trim()) return;

    // LangGraph emits three classDef declarations at the bottom of the
    // .mmd file with hard-coded fills (#f2f0ff default, #bfb6fc last,
    // fill-opacity:0 first). Those become inline styles on the rendered
    // SVG and win the cascade against our scoped CSS theme — leaving
    // pale-lavender boxes with unreadable text on the dark site.
    // Rewrite the classDefs to match the monochrome theme before
    // passing the source to Mermaid. The class *names* are preserved
    // so :::first / :::last references on __start__ / __end__ still
    // resolve.
    const source = rawSource
      .replace(
        /classDef\s+default\s+[^\n]+/g,
        "classDef default fill:#16191f,stroke:#363b46,color:#e6e8eb,line-height:1.2",
      )
      .replace(
        /classDef\s+first\s+[^\n]+/g,
        "classDef first fill:#1c2027,stroke:#7c8ea3,color:#e6e8eb",
      )
      .replace(
        /classDef\s+last\s+[^\n]+/g,
        "classDef last fill:#1c2027,stroke:#7c8ea3,color:#e6e8eb",
      );

    let mermaid;
    try {
      ({ default: mermaid } = await import("mermaid"));
    } catch (err) {
      console.error("Mermaid import failed:", err);
      return;
    }

    mermaid.initialize({
      startOnLoad: false,
      theme: "base",
      // Default "strict" security level forces label sanitisation that
      // mishandles the <p>__start__</p> wrappers LangGraph emits;
      // "loose" preserves the labels and is safe here because the
      // Mermaid source is a build-time artefact, not user input.
      securityLevel: "loose",
      themeVariables: {
        primaryColor: "#16191f",
        primaryTextColor: "#e6e8eb",
        primaryBorderColor: "#363b46",
        lineColor: "#7c8ea3",
        secondaryColor: "#1c2027",
        tertiaryColor: "#1c2027",
        background: "#0d0f13",
        mainBkg: "#16191f",
        nodeBorder: "#363b46",
        clusterBkg: "#1c2027",
        clusterBorder: "#363b46",
        edgeLabelBackground: "#16191f",
        fontFamily: "JetBrains Mono, ui-monospace, monospace",
        fontSize: "13px",
      },
    });

    try {
      const { svg } = await mermaid.render("attestloop-pipeline-svg", source);
      host.innerHTML = svg;
      host.setAttribute("data-rendered", "true");
    } catch (err) {
      console.error("Mermaid render failed:", err);
      host.setAttribute("data-rendered", "error");
      const fallback = host.querySelector<HTMLElement>(".mermaid-fallback");
      if (fallback) {
        fallback.textContent =
          "Pipeline diagram failed to render. The Mermaid source is at docs/orchestration/v6_pipeline.mmd in the repo.";
      }
    }
  }

  function scheduleRender() {
    const host = document.querySelector<HTMLDivElement>(
      "div.mermaid-host[data-mermaid-source]",
    );
    if (!host) return;
    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              obs.disconnect();
              renderPipelineDiagram();
              return;
            }
          }
        },
        { rootMargin: "200px" },
      );
      observer.observe(host);
    } else {
      renderPipelineDiagram();
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", scheduleRender);
  } else {
    scheduleRender();
  }
</script>
