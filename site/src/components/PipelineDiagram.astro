---
import classifierLogs from "../content/runs/v6_classifier.json";
import extractorLogs from "../content/runs/v6_extractor.json";
import mapperLogs from "../content/runs/v6_mapper.json";
import criticLogs from "../content/runs/v6_critic_calls.json";
import criticDecisionsFile from "../content/runs/v6_critic.json";
import obligationsFile from "../content/runs/v6_obligations.json";
import mappingsFile from "../content/runs/v6_mappings.json";
import classifierPrompt from "../content/prompts/classifier.md?raw";
import extractorPrompt from "../content/prompts/extractor.md?raw";
import mapperPrompt from "../content/prompts/mapper.md?raw";
import criticPrompt from "../content/prompts/critic.md?raw";
import mermaidSource from "../content/orchestration/v6_pipeline.mmd?raw";

// Shape of a single LLMCallLog entry, matching the Pydantic model.
interface LogEntry {
  agent: string;
  model: string;
  prompt_version: string;
  input_tokens: number;
  output_tokens: number;
  cost_usd: number;
  latency_ms: number;
  started_at: string;
  prompt: string;
  response: string;
  cache_creation_input_tokens?: number | null;
  cache_read_input_tokens?: number | null;
}

const classifier = classifierLogs as LogEntry[];
const extractor = extractorLogs as LogEntry[];
const mapper = mapperLogs as LogEntry[];
const critic = criticLogs as LogEntry[];

interface CriticDecision {
  obligation_id: string;
  decision: "confirm" | "flag_for_review";
  reasoning: string;
  confidence: number;
  reviewed_mappings: string[];
}
const criticDecisions = (criticDecisionsFile as { decisions: CriticDecision[] })
  .decisions;
const criticReviewed = criticDecisions.length;
const criticFlagged = criticDecisions.filter(
  (d) => d.decision === "flag_for_review",
).length;
const criticConfirmed = criticReviewed - criticFlagged;
const criticFlagRate = criticReviewed
  ? criticFlagged / criticReviewed
  : 0;

// ───────────── publication snippet (Classifier input) ─────────────
// We don't ship publication.json (5 MB raw_html); pull the first 500 chars
// of cleaned text out of the classifier's stored prompt instead — the
// prompt embeds the same passage that was sent to the model.
function extractPublicationSnippet(promptText: string): {
  title: string;
  snippet: string;
} {
  const titleMatch = promptText.match(/Publication title:\s*(.+)/);
  const beginIdx = promptText.indexOf("--- BEGIN PUBLICATION TEXT ---");
  let snippet = "";
  if (beginIdx >= 0) {
    const after = promptText.slice(beginIdx + 31).trimStart();
    snippet = after.slice(0, 500);
  }
  return {
    title: titleMatch ? titleMatch[1].trim() : "(no title)",
    snippet,
  };
}
const publicationSnippet = extractPublicationSnippet(classifier[0].prompt);

// ───────────── extractor sample chunk header + first 500 chars ─────────────
function extractChunkSample(promptText: string): string {
  const beginIdx = promptText.indexOf("--- BEGIN PUBLICATION TEXT");
  if (beginIdx < 0) return "";
  const after = promptText.slice(beginIdx);
  // Take the BEGIN line + 500 chars after the newline that follows it
  const newline = after.indexOf("\n");
  if (newline < 0) return "";
  return after.slice(0, newline + 1) + after.slice(newline + 1, newline + 501);
}
const chunk1Sample = extractChunkSample(extractor[0].prompt);

// ───────────── metrics aggregation ─────────────
function median(nums: number[]): number {
  if (nums.length === 0) return 0;
  const sorted = [...nums].sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2
    ? sorted[mid]
    : Math.round((sorted[mid - 1] + sorted[mid]) / 2);
}

function aggregate(logs: LogEntry[]) {
  return {
    model: logs[0]?.model ?? "—",
    calls: logs.length,
    inputTokens: logs.reduce((s, e) => s + e.input_tokens, 0),
    outputTokens: logs.reduce((s, e) => s + e.output_tokens, 0),
    costUsd: logs.reduce((s, e) => s + e.cost_usd, 0),
    p50LatencyMs: median(logs.map((e) => e.latency_ms)),
  };
}

// Sonnet 4.6 input price $3 / MTok; cache_read price $0.30 / MTok.
// Savings = cache_read_tokens × ($3 − $0.30) / 1 000 000 = cache_read × $2.70/M.
function cacheStats(logs: LogEntry[]) {
  const reads = logs.map((e) => e.cache_read_input_tokens ?? 0);
  const hits = reads.filter((n) => n > 0).length;
  const totalRead = reads.reduce((s, n) => s + n, 0);
  const savingsUsd = (totalRead * 2.7) / 1_000_000;
  const cold = logs[0]?.latency_ms ?? 0;
  const warm = logs.slice(1);
  const warmMean = warm.length
    ? Math.round(warm.reduce((s, e) => s + e.latency_ms, 0) / warm.length)
    : 0;
  return {
    hitRate: logs.length ? hits / logs.length : 0,
    savingsUsd,
    coldLatencyMs: cold,
    warmMeanLatencyMs: warmMean,
  };
}

const classifierMetrics = aggregate(classifier);
const extractorMetrics = aggregate(extractor);
const mapperMetrics = aggregate(mapper);
const criticMetrics = aggregate(critic);
const mapperCache = cacheStats(mapper);
const criticCache = cacheStats(critic);

// ───────────── output samples ─────────────
const classifierOutput = JSON.parse(classifier[0].response);
const extractorChunk1Sample = JSON.parse(extractor[0].response).obligations[0];
const obligationSample = obligationsFile.obligations[0];
const mapperOBL001Sample =
  mappingsFile.mappings.find((m) => m.obligation_id === "EUAIA-OBL-001") ??
  mappingsFile.mappings[0];

// Critic sample: pick the first flag_for_review entry so the panel
// shows the more interesting decision shape rather than a "confirm".
const criticDecisionSample =
  criticDecisions.find((d) => d.decision === "flag_for_review") ??
  criticDecisions[0];
const criticReviewedObligation = criticDecisionSample
  ? obligationsFile.obligations.find(
      (o) => o.id === criticDecisionSample.obligation_id,
    ) ?? obligationsFile.obligations[0]
  : obligationsFile.obligations[0];
const criticReviewedMappings = criticDecisionSample
  ? mappingsFile.mappings.filter(
      (m) => m.obligation_id === criticDecisionSample.obligation_id,
    )
  : [];

// ───────────── word count helper ─────────────
function wordCount(text: string): number {
  return text.trim().split(/\s+/).filter(Boolean).length;
}

// ───────────── agent specs ─────────────
// All five entries below are LLM-driven agents in v2.0.0. The four
// passive components (Watcher, Gap analyser, Drafter, Reviewer queue)
// are listed in a separate "Code, not agent" callout below the panels
// since they're deterministic code, not model calls.
type Status = "active" | "rare-fire";
const STATUS_LABELS: Record<Status, string> = {
  active: "Active in v2.0.0",
  "rare-fire": "Active in v2.0.0 · rarely fires",
};

interface AgentSpec {
  id: string;
  name: string;
  blurb: string;
  status: Status;
  role: string;
  prompt:
    | { kind: "file"; path: string; content: string }
    | { kind: "code"; codePath: string };
  input:
    | { mode: "code"; body: string }
    | { mode: "json"; intro?: string; body: unknown }
    | { mode: "text"; intro?: string; body: string };
  output:
    | { mode: "code"; body: string }
    | { mode: "json"; intro?: string; body: unknown }
    | { mode: "text"; intro?: string; body: string };
  metrics?: ReturnType<typeof aggregate> & {
    cache?: ReturnType<typeof cacheStats>;
  };
}

const agents: AgentSpec[] = [
  {
    id: "classifier",
    name: "Classifier",
    blurb: "Haiku 4.5 · in scope?",
    status: "active",
    role: "Decides whether a fetched publication is in scope for the named regulation, and what category of document it is. Runs once per pipeline invocation. If the verdict is in_scope=False at confidence ≥ 0.7 the pipeline routes straight to the out-of-scope report; below 0.7 the Clarifier re-runs classification with augmented context before committing.",
    prompt: {
      kind: "file",
      path: "src/attestloop/regulations/eu_ai_act/classifier.md",
      content: classifierPrompt,
    },
    input: {
      mode: "text",
      intro: `Publication title: ${publicationSnippet.title}`,
      body: publicationSnippet.snippet,
    },
    output: {
      mode: "json",
      body: classifierOutput,
    },
    metrics: classifierMetrics,
  },
  {
    id: "clarifier",
    name: "Clarifier",
    blurb: "Re-classifies low-confidence",
    status: "rare-fire",
    role: "Triggered only when the Classifier returns in_scope=False at confidence < 0.7. Extracts additional context (table of contents, first 5 pages, or section headings — whichever is most informative) and re-runs the Classifier on the augmented input. The Clarifier itself makes no classification decision; its single LLM call is a re-invocation of the Classifier (Haiku) on the augmented prompt. Rarely fires on real regulator URLs that classify confidently — the Commission Guidelines URL never triggers it. Exercised end-to-end via scripts/smoke_clarifier.py against a synthetic ambiguous fixture.",
    prompt: {
      kind: "code",
      codePath:
        "src/attestloop/agents/clarifier.py (delegates the LLM call to the Classifier)",
    },
    input: {
      mode: "text",
      body: "(when triggered: the original cleaned text plus an --- ADDITIONAL CONTEXT FROM CLARIFIER --- block carrying the table of contents, first 5 pages, or section headings extracted from the publication)",
    },
    output: {
      mode: "text",
      body: "(when triggered: a re-classification ClassifierOutput plus a structured ClarifierOutput recording the initial classification, the source of the augmented context, and the re-classification verdict — preserved in clarifier_output.json for audit)",
    },
  },
  {
    id: "extractor",
    name: "Extractor",
    blurb: "Sonnet 4.6 · 12 chunks",
    status: "active",
    role: "Pulls discrete, citeable obligations from the publication body. Runs once per chunk; the v6 source PDF is split into 12 ~40 000-character chunks with a 2 000-character overlap. After all chunks complete, a fuzzy deduplicator merges paraphrased duplicates that span chunk boundaries.",
    prompt: {
      kind: "file",
      path: "src/attestloop/regulations/eu_ai_act/extractor.md",
      content: extractorPrompt,
    },
    input: {
      mode: "text",
      intro:
        "12 chunks of ~40 000 chars each, total 428 902 chars. Sample (chunk 1):",
      body: chunk1Sample,
    },
    output: {
      mode: "json",
      intro: `${obligationsFile.obligations.length} obligations extracted across 12 chunks (paraphrased duplicates merged via rapidfuzz). Sample output (first obligation from chunk 1):`,
      body: extractorChunk1Sample,
    },
    metrics: extractorMetrics,
  },
  {
    id: "mapper",
    name: "Mapper",
    blurb: "Sonnet 4.6 · 8-way parallel",
    status: "active",
    role: "Maps each obligation to between zero and three controls in the chosen framework, with a confidence score and reasoning. v6 dispatches the per-obligation calls through asyncio.gather with an asyncio.Semaphore(8); the public sync entrypoint is unchanged but mapper wall-clock collapses 8.13× vs the v5-equivalent serial baseline. The 0.75 confidence floor is what produces the unmapped list — empty mappings for procedural duties NIST AI RMF doesn't cover are surfaced honestly rather than slot-filled.",
    prompt: {
      kind: "file",
      path: "src/attestloop/frameworks/nist_ai_rmf/mapper.md",
      content: mapperPrompt,
    },
    input: {
      mode: "json",
      intro: `${obligationsFile.obligations.length} obligations, dispatched 8 at a time via asyncio.Semaphore. Sample input below:`,
      body: obligationSample,
    },
    output: {
      mode: "json",
      intro: `${mappingsFile.mappings.length} high-confidence mappings, ${obligationsFile.obligations.length - new Set(mappingsFile.mappings.map((m) => m.obligation_id)).size} obligations unmapped. Sample mapping for EUAIA-OBL-001:`,
      body: mapperOBL001Sample,
    },
    metrics: { ...mapperMetrics, cache: mapperCache },
  },
  {
    id: "critic",
    name: "Critic",
    blurb: `Sonnet 4.6 · ${criticReviewed} reviewed`,
    status: "active",
    role: `Second-pass review of any obligation whose Mapper output includes at least one mapping below 0.80 confidence. Returns one of two decisions: confirm (mappings stand) or flag_for_review (mappings stand, but the report annotates them as flagged). The Critic is advisory — it does not auto-replace mappings, so a confidently-wrong Critic can't silently overwrite a defensible Mapper output. On the canonical v6 run it reviewed ${criticReviewed} obligations and flagged ${criticFlagged} (${(criticFlagRate * 100).toFixed(0)}% flag rate); each flag named a specific control being stretched semantically and at least one alternative the Mapper missed.`,
    prompt: {
      kind: "file",
      path: "src/attestloop/frameworks/nist_ai_rmf/critic.md",
      content: criticPrompt,
    },
    input: {
      mode: "text",
      intro:
        criticDecisionSample
          ? `Per-obligation: one Obligation plus the Mapper's proposed mappings plus the full controls library. Sample input for ${criticDecisionSample.obligation_id}:`
          : "Per-obligation: one Obligation plus the Mapper's proposed mappings plus the full controls library.",
      body: criticDecisionSample
        ? JSON.stringify(
            {
              obligation: criticReviewedObligation,
              proposed_mappings: criticReviewedMappings,
            },
            null,
            2,
          )
        : "(no Critic decisions in this run)",
    },
    output: {
      mode: "json",
      intro: `${criticReviewed} CriticDecision records: ${criticConfirmed} confirmed, ${criticFlagged} flagged for human review. Sample decision below:`,
      body: criticDecisionSample ?? null,
    },
    metrics: { ...criticMetrics, cache: criticCache },
  },
];

const formatTokens = (n: number) =>
  n.toLocaleString("en-US", { maximumFractionDigits: 0 });
const formatCost = (n: number) => `$${n.toFixed(2)}`;
const formatLatency = (ms: number) => `${(ms / 1000).toFixed(2)}s`;
const formatPercent = (frac: number) => `${(frac * 100).toFixed(0)}%`;
---

<section
  id="how-it-works"
  class="border-t border-border-subtle py-18 sm:py-24 px-6 sm:px-8"
>
  <div class="max-w-[64rem] mx-auto fade-in">
    <p
      class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted mb-6"
    >
      Pipeline
    </p>

    <h2
      class="font-serif font-normal text-text-primary text-[1.5rem] sm:text-[2rem] leading-tight mb-6"
    >
      How the pipeline works
    </h2>

    <p
      class="text-base text-text-secondary leading-relaxed max-w-[42rem] mb-10"
    >
      The diagram below is generated directly from the compiled LangGraph
      state machine — <code class="font-mono text-text-primary">scripts/render_graph.py</code>
      writes the Mermaid source to <code class="font-mono text-text-primary">docs/orchestration/v6_pipeline.mmd</code>,
      which the page renders client-side. If the orchestration changes, the
      diagram regenerates automatically. v2.0.0's five-agent topology with
      conditional routing is what's drawn here. Click any agent below for
      role, prompt, sample input and output, and per-call metrics from the
      canonical v6 run.
    </p>

    <!-- Mermaid diagram, generated from the compiled LangGraph state
         machine. Source lives at site/src/content/orchestration/
         v6_pipeline.mmd; the script tag below renders it on mount.
         The source is delivered via a `data-mermaid-source` attribute
         (not as text content) so Astro's CSS scoping doesn't trip
         over the rendered SVG, and the host div is replaced outright
         when the render succeeds. -->
    <div class="mermaid-frame mb-10">
      <p class="mermaid-caption text-xs font-mono uppercase tracking-[0.18em] text-text-muted">
        Compiled LangGraph state machine · v2.0.0
      </p>
      <div
        class="mermaid-host"
        role="img"
        aria-label="Pipeline state-machine diagram"
        data-mermaid-source={mermaidSource}
      >
        <p class="mermaid-fallback text-sm font-mono text-text-muted">
          Loading diagram… (if this persists, see
          <code class="font-mono text-text-primary">docs/orchestration/v6_pipeline.mmd</code>
          in the repo for the source.)
        </p>
      </div>
    </div>

    <!-- Agent selector row. Each button toggles its expansion panel
         below. Keyboard navigation (arrow keys + Escape) is wired in
         the script block at the bottom of the component. -->
    <p class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted mb-3">
      LLM agents · click to expand
    </p>
    <div class="agent-selector-row mb-12" role="list">
      {
        agents.map((a) => (
          <button
            type="button"
            class:list={["agent-selector", `status-${a.status}`]}
            data-agent-id={a.id}
            aria-controls={`agent-panel-${a.id}`}
            aria-expanded="false"
            role="listitem"
          >
            <p class="text-xs font-mono text-text-primary leading-tight">
              {a.name}
            </p>
            <p class="text-[0.7rem] font-mono text-text-muted mt-1 leading-tight">
              {a.blurb}
            </p>
          </button>
        ))
      }
    </div>

    <!-- Agent detail panels. All seven rendered as hidden articles; JS
         toggles visibility one at a time. -->
    <div id="agent-panels" class="agent-panels-root">
      {
        agents.map((a) => {
          const isActive = a.status === "active" || a.status === "rare-fire";
          const promptHasContent = a.prompt.kind === "file";
          const promptWords =
            a.prompt.kind === "file" ? wordCount(a.prompt.content) : 0;

          return (
            <article
              id={`agent-panel-${a.id}`}
              class="agent-panel border border-border-default bg-bg-elevated"
              data-agent={a.id}
              hidden
            >
              <header class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 px-6 sm:px-8 py-5 sm:py-6 border-b border-border-subtle">
                <div class="flex items-baseline gap-3 flex-wrap">
                  <h3 class="font-serif font-normal text-text-primary text-[1.5rem] leading-tight">
                    {a.name}
                  </h3>
                  <span
                    class:list={[
                      "text-xs font-mono uppercase tracking-[0.18em]",
                      a.status === "active" && "text-accent",
                      a.status === "rare-fire" && "text-text-secondary",
                    ]}
                  >
                    {STATUS_LABELS[a.status]}
                  </span>
                </div>
                <button
                  type="button"
                  class="agent-panel-close self-start text-text-secondary hover:text-text-primary transition-colors duration-150"
                  data-panel-close
                  aria-label={`Close ${a.name} panel`}
                >
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 18 18"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M4 4 L14 14 M14 4 L4 14"
                      stroke="currentColor"
                      stroke-width="1.4"
                      stroke-linecap="round"
                    />
                  </svg>
                </button>
              </header>

              <div class="px-6 sm:px-8 py-6 sm:py-8 space-y-7">
                <div>
                  <p class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted mb-3">
                    Role
                  </p>
                  <p class="text-text-secondary leading-relaxed max-w-[42rem]">
                    {a.role}
                  </p>
                </div>

                <details class="panel-details">
                  <summary class="panel-summary">
                    <span class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted">
                      System prompt
                    </span>
                    {a.prompt.kind === "file" ? (
                      <code class="text-xs font-mono text-text-secondary truncate-path">
                        {a.prompt.path}
                      </code>
                    ) : (
                      <code class="text-xs font-mono text-text-muted">
                        {a.prompt.codePath}
                      </code>
                    )}
                    <span class="panel-toggle text-xs font-mono text-text-secondary">
                      {promptHasContent
                        ? `Show full prompt (${promptWords} words)`
                        : "(no LLM prompt)"}
                    </span>
                  </summary>
                  {a.prompt.kind === "file" ? (
                    <pre class="panel-codeblock"><code>{a.prompt.content}</code></pre>
                  ) : (
                    <p class="text-sm font-mono text-text-muted mt-4">
                      (no prompt — implemented as code in {a.prompt.codePath})
                    </p>
                  )}
                </details>

                <details class="panel-details">
                  <summary class="panel-summary">
                    <span class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted">
                      Input (v6 run)
                    </span>
                    <span class="panel-toggle text-xs font-mono text-text-secondary">
                      Show
                    </span>
                  </summary>
                  <div class="mt-4 space-y-3">
                    {a.input.mode !== "code" && "intro" in a.input && a.input.intro && (
                      <p class="text-sm text-text-secondary">{a.input.intro}</p>
                    )}
                    {a.input.mode === "json" ? (
                      <pre class="panel-codeblock"><code>{JSON.stringify(a.input.body, null, 2)}</code></pre>
                    ) : (
                      <pre class="panel-codeblock"><code>{a.input.body as string}</code></pre>
                    )}
                  </div>
                </details>

                <details class="panel-details">
                  <summary class="panel-summary">
                    <span class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted">
                      Output (v6 run)
                    </span>
                    <span class="panel-toggle text-xs font-mono text-text-secondary">
                      Show
                    </span>
                  </summary>
                  <div class="mt-4 space-y-3">
                    {a.output.mode !== "code" &&
                      "intro" in a.output && a.output.intro && (
                        <p class="text-sm text-text-secondary">
                          {a.output.intro}
                        </p>
                      )}
                    {a.output.mode === "json" ? (
                      <pre class="panel-codeblock"><code>{JSON.stringify(a.output.body, null, 2)}</code></pre>
                    ) : (
                      <pre class="panel-codeblock"><code>{a.output.body as string}</code></pre>
                    )}
                  </div>
                </details>

                {isActive && a.metrics && (
                  <div>
                    <p class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted mb-4">
                      Metrics
                    </p>
                    <div class="metrics-grid">
                      <div class="metric-cell">
                        <p class="metric-cap">Model</p>
                        <p class="metric-value-mono">{a.metrics.model}</p>
                      </div>
                      <div class="metric-cell">
                        <p class="metric-cap">Total calls</p>
                        <p class="metric-value-num">{a.metrics.calls}</p>
                      </div>
                      <div class="metric-cell">
                        <p class="metric-cap">Input tokens</p>
                        <p class="metric-value-num">
                          {formatTokens(a.metrics.inputTokens)}
                        </p>
                      </div>
                      <div class="metric-cell">
                        <p class="metric-cap">Output tokens</p>
                        <p class="metric-value-num">
                          {formatTokens(a.metrics.outputTokens)}
                        </p>
                      </div>
                      <div class="metric-cell">
                        <p class="metric-cap">Cost</p>
                        <p class="metric-value-num">
                          {formatCost(a.metrics.costUsd)}
                        </p>
                      </div>
                      <div class="metric-cell">
                        <p class="metric-cap">p50 latency</p>
                        <p class="metric-value-num">
                          {formatLatency(a.metrics.p50LatencyMs)}
                        </p>
                      </div>
                      {a.metrics.cache && (
                        <>
                          <div class="metric-cell">
                            <p class="metric-cap">Cache hit rate</p>
                            <p class="metric-value-num">
                              {formatPercent(a.metrics.cache.hitRate)}
                            </p>
                          </div>
                          <div class="metric-cell">
                            <p class="metric-cap">Cache savings</p>
                            <p class="metric-value-num">
                              {formatCost(a.metrics.cache.savingsUsd)}
                            </p>
                          </div>
                          <div class="metric-cell">
                            <p class="metric-cap">Cold call</p>
                            <p class="metric-value-num">
                              {formatLatency(a.metrics.cache.coldLatencyMs)}
                            </p>
                          </div>
                          <div class="metric-cell">
                            <p class="metric-cap">Warm mean</p>
                            <p class="metric-value-num">
                              {formatLatency(
                                a.metrics.cache.warmMeanLatencyMs,
                              )}
                            </p>
                          </div>
                        </>
                      )}
                    </div>
                  </div>
                )}
              </div>
            </article>
          );
        })
      }
    </div>

    <!-- Code-not-agent callout: the four passive components in the
         pipeline are deterministic code, not LLM-driven agents. v6
         keeps the separation explicit so the LLM agent count above
         (five) isn't inflated by support code that doesn't make
         model calls. -->
    <aside class="code-not-agent mt-14">
      <p class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted mb-3">
        Code, not agent
      </p>
      <p class="text-sm text-text-secondary leading-relaxed max-w-[42rem] mb-5">
        Four passive components in the pipeline. Each is deterministic
        Python in v2.0.0, not an LLM-driven agent — adding a model call
        where code already does the job is a common failure mode in
        agentic projects.
      </p>
      <ul class="code-not-agent-list">
        <li>
          <span class="cna-name">Watcher</span>
          <span class="cna-body">
            Architected, not yet shipping. Will poll regulator sources
            (EUR-Lex, FCA Handbook, EBA, ICO) on a schedule, deduplicate
            against history, and queue new in-scope publications. v3
            backlog work; v2.0.0 runs on demand against a single URL.
          </span>
        </li>
        <li>
          <span class="cna-name">Gap analyser</span>
          <span class="cna-body">
            Folded into the Mapper's confidence floor. Any obligation
            with zero high-confidence mappings is surfaced in the
            report's "Obligations with no high-confidence framework
            mapping" section. The 0.75 confidence floor is the gap-
            analysis policy.
          </span>
        </li>
        <li>
          <span class="cna-name">Drafter</span>
          <span class="cna-body">
            Report builder code. Composes the executive summary,
            obligations table, control mappings table, unmapped section,
            Critic flags, and provenance footer from the typed Pydantic
            outputs of the upstream agents. Pure templating — no LLM call.
          </span>
        </li>
        <li>
          <span class="cna-name">Reviewer queue</span>
          <span class="cna-body">
            On-disk artefacts. Each run writes
            <code class="font-mono text-text-primary">runs/&lt;run_id&gt;/</code>
            with the report, run metadata, structured outputs, and per-
            agent call logs. Reviewing means opening the directory; v3
            backlog adds a proper in-process queue.
          </span>
        </li>
      </ul>
    </aside>
  </div>
</section>

