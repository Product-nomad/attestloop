---
interface Props {
  index: number;
  total: number;
  anchor: string;
  question: string;
  elaboration: string;
  technicalNote: string;
}

const { index, total, anchor, question, elaboration, technicalNote } =
  Astro.props;
const indexLabel = String(index).padStart(2, "0");
const totalLabel = String(total).padStart(2, "0");
---

<section
  id={anchor}
  class="border-t border-border-subtle py-18 sm:py-24 px-6 sm:px-8"
>
  <div class="max-w-[64rem] mx-auto fade-in">
    <p
      class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted mb-6"
    >
      Question {indexLabel} / {totalLabel}
    </p>

    <h2
      class="font-serif font-normal text-text-primary text-[1.5rem] sm:text-[2rem] leading-tight mb-4"
    >
      {question}
    </h2>

    <p
      class="text-base text-text-secondary leading-relaxed max-w-[42rem] mb-10"
    >
      {elaboration}
    </p>

    <div class="mb-8">
      <slot name="answerCard" />
    </div>

    <p
      class="text-sm text-text-muted italic max-w-[42rem] leading-relaxed border-l border-border-subtle pl-4"
    >
      {technicalNote}
    </p>
  </div>
</section>
