---
interface Props {
  index: number;
  total: number;
  anchor: string;
  question: string;
  elaboration: string;
}

const { index, total, anchor, question, elaboration } = Astro.props;
const indexLabel = String(index).padStart(2, "0");
const totalLabel = String(total).padStart(2, "0");
---

<section
  id={anchor}
  class="border-t border-border-subtle py-24 sm:py-32 px-6 sm:px-8"
>
  <div class="max-w-[64rem] mx-auto fade-in">
    <p
      class="text-xs font-mono uppercase tracking-[0.18em] text-text-muted mb-6"
    >
      Question {indexLabel} / {totalLabel}
    </p>

    <h2
      class="font-serif font-normal text-text-primary text-[1.5rem] sm:text-[2rem] leading-tight mb-4"
    >
      {question}
    </h2>

    <p
      class="text-base text-text-secondary leading-relaxed max-w-[42rem] mb-10"
    >
      {elaboration}
    </p>

    <div
      class="border border-border-subtle bg-bg-elevated px-5 py-4 text-sm text-text-muted font-mono"
    >
      Content lands in task B.
    </div>
  </div>
</section>
