---
type Status = "live-v2" | "live-v1" | "architected" | "backlog";

interface Item {
  status: Status;
  statusLabel: string;
  body: string;
}

const items: Item[] = [
  {
    status: "live-v2",
    statusLabel: "Live in v2.0.0",
    body: "LangGraph state machine orchestration with five LLM-driven agents and conditional routing. Critic agent for second-pass review of low-confidence mappings. 8-way concurrent Mapper execution.",
  },
  {
    status: "live-v1",
    statusLabel: "Live in v1",
    body: "Single-document attestation against EU AI Act and NIST AI RMF, on demand. Available under V5_EQUIVALENT config flag for ~$1.31/run when audit-grade output isn't required.",
  },
  {
    status: "architected",
    statusLabel: "Architected, not yet shipping",
    body: "Watcher agent polls regulator sources on a schedule, deduplicates against history, queues new in-scope publications. Per-regulator scrape adapters in v3 backlog.",
  },
  {
    status: "backlog",
    statusLabel: "v3 backlog",
    body: "Multi-framework support (ISO 42001, SOC 2 AI Trust Criteria, customer-supplied control libraries). Critic parallelisation for 5–7 minute total runtime. Mapper batching for sustained throughput.",
  },
];

const statusClass: Record<Status, string> = {
  "live-v2": "text-accent",
  "live-v1": "text-text-secondary",
  architected: "text-text-secondary",
  backlog: "text-text-muted",
};
---

<div class="space-y-4">
  {
    items.map((item) => (
      <div class="border border-border-subtle bg-bg-elevated px-6 py-6 sm:px-8 sm:py-7">
        <p
          class:list={[
            "text-xs font-mono uppercase tracking-[0.18em] mb-3",
            statusClass[item.status],
          ]}
        >
          {item.statusLabel}
        </p>
        <p class="font-serif text-text-primary text-base sm:text-lg leading-relaxed">
          {item.body}
        </p>
      </div>
    ))
  }
</div>

<p class="text-xs font-mono text-text-muted mt-5 leading-relaxed">
  Honesty about scope is itself an audit-trail feature. Where v1 doesn't
  reach, the system says so.
</p>
