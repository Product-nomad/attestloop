---
type Status = "today" | "architected" | "backlog";

interface Item {
  status: Status;
  statusLabel: string;
  body: string;
}

const items: Item[] = [
  {
    status: "today",
    statusLabel: "Today (v2.0.0)",
    body: "On-demand. Point Attestloop at any regulator URL and it tells you whether the publication is in scope and what obligations it contains. Useful for ad-hoc triage but not for forward monitoring.",
  },
  {
    status: "architected",
    statusLabel: "Architected, shipping in v3",
    body: "Watcher agent polls regulator sources on a schedule — EUR-Lex, FCA Handbook, EBA, ICO, ESMA — deduplicates against history, and surfaces new in-scope publications before they hit your inbox manually. Per-regulator scrape adapters in development; the architecture and registry already support multi-source polling.",
  },
  {
    status: "backlog",
    statusLabel: "v3 backlog",
    body: "Forward-looking signals from regulator pipelines: published consultations, draft technical standards, work programmes. Distinguishes between 'binding next month' and 'consultation closing in March' so compliance teams can prioritise. Gives boards real horizon answers, not just last-week summaries.",
  },
];

const statusClass: Record<Status, string> = {
  today: "text-accent",
  architected: "text-text-secondary",
  backlog: "text-text-muted",
};
---

<div class="space-y-4">
  {
    items.map((item) => (
      <div class="border border-border-subtle bg-bg-elevated px-6 py-6 sm:px-8 sm:py-7">
        <p
          class:list={[
            "text-xs font-mono uppercase tracking-[0.18em] mb-3",
            statusClass[item.status],
          ]}
        >
          {item.statusLabel}
        </p>
        <p class="font-serif text-text-primary text-base sm:text-lg leading-relaxed">
          {item.body}
        </p>
      </div>
    ))
  }
</div>

<p class="text-sm text-text-secondary mt-6 leading-relaxed max-w-[42rem]">
  Today: ad-hoc triage. v3: scheduled monitoring. v3+: regulator pipeline
  awareness. Honesty about which question Attestloop answers when matters
  as much as the answers themselves.
</p>

<p class="text-xs font-mono text-text-muted mt-5 leading-relaxed">
  The Watcher agent is the v3 work that converts Attestloop from on-demand
  triage to scheduled regulatory monitoring. Multi-source polling,
  per-regulator adapters, deduplication against historical runs, and
  alerting integration are all tracked in the GitHub backlog.
</p>
